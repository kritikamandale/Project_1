{
  "name": "Arlo-backend",
  "version": "1.0.0",
  "description": "Arlo backend API — AI proxy, auth, payments",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "lint": "eslint . --ext .js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.26.0",
    "cors": "2.8.5",
    "express": "4.19.2",
    "express-rate-limit": "7.3.1",
    "firebase-admin": "12.2.0",
    "helmet": "7.1.0",
    "morgan": "1.10.0",
    "razorpay": "^2.9.6",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "eslint": "8.57.0",
    "jest": "29.7.0",
    "nodemon": "3.1.4",
    "supertest": "7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ]
  }
}

