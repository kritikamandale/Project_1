# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Comma-separated list of allowed chrome-extension:// origins
# Get your extension ID from chrome://extensions after loading unpacked
ALLOWED_ORIGINS=chrome-extension://your-extension-id-here

# ── Firebase Admin ─────────────────────────────────────────────────────────────
# Option A: paste the entire service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Option B: path to service account file (local dev only)
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
FIREBASE_PROJECT_ID=your-project-id

# ── Claude (Anthropic) ────────────────────────────────────────────────────────
# NEVER commit this key. Set it as a secret in Railway/Render.
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
